# 백엔드 환경변수
# Supabase Connection String (Pooler 권장 - IPv4 호환)
# Supabase 대시보드 → Project Settings → Database → Connection string → Transaction (port 6543)
# 사용자명은 postgres.{project_ref}, 비밀번호는 프로젝트 생성 시 설정한 DB 비밀번호
# 예: postgresql://postgres.ajncesrkhlusqginyscw:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

PORT=3000
NODE_ENV=production

# 프론트엔드 도메인 (Vercel 배포 후 URL)
# 예: https://ezone-mes.vercel.app
CORS_ORIGIN=http://localhost:5173

# JWT 서명 키 (32자 이상 랜덤 문자열). 절대 공개 저장소에 커밋 금지!
# 생성 예시: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=7d
